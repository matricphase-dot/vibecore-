# Supabase Credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis Credentials
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Inference Server Credentials (ngrok URL from Colab Notebook)
GEMMA_BASE_URL=https://xxxx.ngrok-free.app
GEMMA_MODEL_NAME=gemma-vibecore

# Commercial Provider API Keys (Fallback options)
OPENAI_API_KEY=sk-proj-...
GROQ_API_KEY=gsk-...
ANTHROPIC_API_KEY=sk-ant-...

# Razorpay Payments Configurations (INR pricing)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# PayPal Payments Configurations (USD pricing)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# App Configurations
PORT=3001
JWT_SECRET=your-64-character-random-jwt-string-secret
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cache Configurations
SEMANTIC_CACHE_THRESHOLD=0.88
CACHE_TTL_SECONDS=86400
